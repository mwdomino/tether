# Brewfile for tether.
#
# Usage:
#   brew bundle --file=./Brewfile
#
# This taps mwdomino/tap (the auto-published Homebrew tap that goreleaser
# pushes to on every release) and installs the tether binary. After install:
#
#   tether install         # registers the per-user host daemon (desktop side)
#
# For the headless agent shim, see README.md ("3. Headless box").

tap "mwdomino/tap"
brew "tether"
